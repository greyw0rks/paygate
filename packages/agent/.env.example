# Hedera Testnet credentials (get free account at https://portal.hedera.com)
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=0x...

# Anthropic API key for Claude LLM
ANTHROPIC_API_KEY=sk-ant-...

# Optional: pre-created HCS topic ID for on-chain audit trail
# If not set, PaygateAuditHook still logs in-memory; HcsAuditTrailHook is disabled
HEDERA_AUDIT_TOPIC_ID=0.0.XXXXX

# Server port (default 3001)
PORT=3001
